# App
PORT=3000
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=fx_trading_app

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
JWT_SECRET=supersecretkey
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Mail
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your_email@gmail.com
MAIL_PASS=your_app_password_here

# FX API (uses open.er-api.com — no key required)
FX_API_BASE_URL=https://open.er-api.com/v6/latest
FX_RATE_CACHE_TTL=300
FX_RATE_MAX_AGE=1800

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=10

# Admin Seed (created on first startup if not exists)
ADMIN_EMAIL=admin@fxtradingapp.com
ADMIN_PASSWORD=Admin@123456
